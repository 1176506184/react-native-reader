{
  "name": "@tangfeifan/react-native-reader",
  "version": "0.2.0",
  "description": "A React Native novel and ebook reader core with pagination, chapter boundaries, locked pages, and five page-turn modes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1176506184/react-native-reader.git"
  },
  "homepage": "https://github.com/1176506184/react-native-reader#readme",
  "bugs": {
    "url": "https://github.com/1176506184/react-native-reader/issues"
  },
  "keywords": [
    "react-native",
    "reader",
    "novel",
    "ebook",
    "pagination",
    "page-flip",
    "page-curl",
    "skia",
    "reanimated"
  ],
  "main": "src/index.ts",
  "module": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "check": "npm run typecheck && npm test && npm run pack:dry-run",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.78.0",
    "expo": ">=53.0.0",
    "expo-linear-gradient": ">=14.0.0",
    "@shopify/react-native-skia": ">=2.6.9",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.19.1",
    "react-native-worklets": ">=0.7.0"
  },
  "peerDependenciesMeta": {
    "react-native-worklets": {
      "optional": true
    }
  },
  "dependencies": {
    "htmlparser2": "10.1.0"
  },
  "devDependencies": {
    "@shopify/react-native-skia": "2.6.9",
    "@types/react": "19.2.10",
    "expo-linear-gradient": "55.0.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-worklets": "0.7.2",
    "typescript": "5.9.2",
    "vitest": "4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
